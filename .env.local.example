# ── ArmoredPress Dashboard — local development env ──────────────────────────
# Copy to .env.local and fill in values.
# In production these come from docker-compose.yml / host environment.

# Database
DATABASE_URL=postgresql://apuser:password@localhost:5432/armoredpress

# JWT — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret

# SSO shared secret — must match AP_SSO_SECRET in wp-config.php
AP_SSO_SECRET=CHANGE_ME_sso_secret

# Redis
REDIS_URL=redis://:password@localhost:6379

# RunCloud API
# API v3 token — RunCloud Workspace → Settings → API Management
RUNCLOUD_API_TOKEN=CHANGE_ME

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Autotask ───────────────────────────────────────────────────────────────────
# API Integration Code — Admin > API > Integrations
AUTOTASK_API_INTEGRATION_CODE=CHANGE_ME
# API user credentials
AUTOTASK_API_USERNAME=apiuser@yourdomain.com
AUTOTASK_API_SECRET=CHANGE_ME
# Numeric IDs — discover via GET /api/support/autotask-fields after setting creds
AUTOTASK_QUEUE_ID=0
AUTOTASK_COMPANY_ID=0
AUTOTASK_ISSUE_TYPE_ID=0
AUTOTASK_SOURCE_ID=0
# Sub-issue type IDs
AUTOTASK_SUB_WORDPRESS=0
AUTOTASK_SUB_DNS=0
AUTOTASK_SUB_SSL=0
AUTOTASK_SUB_PERFORMANCE=0
AUTOTASK_SUB_BILLING=0
AUTOTASK_SUB_OTHER=0
