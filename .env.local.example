# ── ArmoredPress Dashboard — local development env ──────────────────────────
# Copy to .env.local and fill in values.
# In production these come from docker-compose.yml / host environment.

# Database
DATABASE_URL=postgresql://apuser:password@localhost:5432/armoredpress

# JWT — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret

# SSO shared secret — must match AP_SSO_SECRET in wp-config.php
AP_SSO_SECRET=CHANGE_ME_sso_secret

# Redis
REDIS_URL=redis://:password@localhost:6379

# RunCloud API
# API v3 token — RunCloud Workspace → Settings → API Management
RUNCLOUD_API_TOKEN=CHANGE_ME

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
