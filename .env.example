# ─────────────────────────────────────────────────────────────────────────────
# ArmoredPress Dashboard — Environment Variables
# Copy to .env and fill in all values before running docker compose up.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Dashboard domain ─────────────────────────────────────────────────────────
DASHBOARD_DOMAIN=dashboard.armoredpress.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=apuser
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=armoredpress

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── Next.js auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_URL=https://dashboard.armoredpress.com
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret_here

# ── ArmoredPress SSO shared secret ───────────────────────────────────────────
# Must match AP_SSO_SECRET defined in wp-config.php on every client WP site.
# Generate with: openssl rand -hex 32
AP_SSO_SECRET=CHANGE_ME_sso_secret_here

# ── RunCloud API ──────────────────────────────────────────────────────────────
RUNCLOUD_API_KEY=CHANGE_ME
RUNCLOUD_API_SECRET=CHANGE_ME

# ── Cloudflare (internal — for ArmoredPress-managed zones, if used later) ────
# CF_API_TOKEN=CHANGE_ME
